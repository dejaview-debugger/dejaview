{
  "name": "dejaview-extension",
  "displayName": "Dejaview",
  "description": "Dejaview Extension",
  "version": "0.1.0",
  "publisher": "TeamDejaView",
  "repository": "https://github.com/dejaview-debugger/dejaview",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onDebug:dejaview-python-pdb"
  ],
  "main": "./out/extension.js",
  "breakpoints": [
    {
      "language": "python"
    }
  ],
  "contributes": {
    "commands": [],
    "debuggers": [
      {
        "type": "dejaview-python-pdb",
        "label": "DejaView Python (pdb)",
        "program": "./out/adapter.js",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the program to debug."
              },
              "pythonPath": {
                "type": "string",
                "description": "Path to the Python interpreter.",
                "default": "python3"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debugged program."
              }
            }
          }
        },
        "languages": [
          "python"
        ],
        "runtime": "node"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0"
  }
}
